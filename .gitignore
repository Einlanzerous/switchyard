# Dependencies
node_modules/

# Build output
dist/
build/
client/dist/
server/dist/
shared/dist/
*.tsbuildinfo

# Caches
.turbo/
.cache/
.vite/
.bun/

# Tests
coverage/

# Playwright local artifacts. None of these should ever be committed —
# the report is regenerated each run, the test-results dir holds traces
# / screenshots / videos for the most recent run, and the .auth dir
# holds a bearer token that grants admin access to the test backend.
client/playwright-report/
client/test-results/
client/playwright/.auth/

# Editor / OS
.vscode/
.idea/
.DS_Store

# Local environment (.env.example IS committed; .env and variants are not)
.env
.env.local
.env.*.local

# Claude Code MCP config — contains a bearer token; set up per clone
.mcp.json

# Logs
*.log

# Local-dev attachment storage (production uses the /data/uploads docker volume)
uploads/

# Knowledge graph — large generated files stay local; cache + report are committed
graphify-out/graph.html
graphify-out/graph.json
graphify-out/manifest.json
graphify-out/cost.json
graphify-out/.graphify_*

# NOT ignored — listed here as a reminder that these ARE committed:
#   bun.lock / bun.lockb       (lockfile, for reproducible installs)
#   server/drizzle/migrations/ (migration history is the schema's source of truth)
#   openapi.yaml               (generated, but committed for diffing across PRs)
