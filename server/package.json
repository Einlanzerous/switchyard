{
  "name": "@switchyard/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "start": "bun dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/lib/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:test:setup": "bun scripts/db-test-setup.ts",
    "dev:seed-sample": "bun scripts/dev-seed-sample.ts",
    "seed:swy": "bun scripts/seed-switchyard-project.ts",
    "seed:test-e2e": "bun scripts/seed-test-fixtures.ts",
    "seed:imperium-fields": "bun scripts/seed-imperium-loop-fields.ts",
    "seed:model-pricing": "bun scripts/seed-model-pricing.ts",
    "openapi:gen": "DATABASE_URL=postgres://codegen@localhost:5432/codegen bun src/lib/openapi-gen.ts",
    "test": "bun test --parallel=1",
    "test:unit": "bun test test/lib/pagination.test.ts test/lib/hmac.test.ts",
    "test:integration": "bun test --parallel=1 test/lib/seed.test.ts test/integration/webhooks.test.ts"
  },
  "dependencies": {
    "@hono/zod-openapi": "^0.18.3",
    "@switchyard/shared": "workspace:*",
    "cron-parser": "^5.5.0",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.13",
    "postgres": "^3.4.5",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "drizzle-kit": "^0.28.1"
  }
}
