# --- switchyard ---
# Connection to the shared Postgres on construct_net.
# In production this is set by docker-compose; for local non-docker dev,
# set DATABASE_URL to a local Postgres or run a one-off compose with the postgres service.
DATABASE_URL=postgres://switchyard_user:change_me@localhost:5432/switchyard?sslmode=disable

# Separate DB for `bun test`. Without this, tests refuse to run.
# Create with:  CREATE DATABASE switchyard_test OWNER switchyard_user;
DATABASE_URL_TEST=postgres://switchyard_user:change_me@localhost:5432/switchyard_test?sslmode=disable

# Port the server listens on (also serves the built Vue client at /).
PORT=4002

# Public base URL used in webhook payloads, attachment URLs, etc.
PUBLIC_URL=http://localhost:4002

# Where attachment files are written. In docker, this is /data/uploads (mounted volume).
UPLOAD_DIR=./uploads

# Bootstrap token. If set, this exact value is registered as an admin token
# attached to magos. If unset and api_tokens is empty on first boot, one is
# auto-generated and printed to stdout + written to ${UPLOAD_DIR}/.bootstrap-token.
BOOTSTRAP_TOKEN=

# Attachment size caps (bytes). Defaults: 25MB / 100MB / 5MB.
ATTACHMENT_MAX_IMAGE_BYTES=26214400
ATTACHMENT_MAX_AUDIO_BYTES=104857600
ATTACHMENT_MAX_TEXT_BYTES=5242880

# Webhook dispatcher tuning.
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_BATCH_SIZE=32

# Signet connector (SWY-165). Points the owner-only admin surfaces at the Signet
# vault daemon's `signet serve` API. Leave both unset to disable — /v1/signet/*
# then reports "not connected" and returns 503 instead of proxying. In docker,
# the base URL is typically http://host.docker.internal:4010. The token is
# Signet's SIGNET_API_TOKEN (the mirror bearer).
SIGNET_BASE_URL=
SIGNET_API_TOKEN=
SIGNET_TIMEOUT_MS=5000
