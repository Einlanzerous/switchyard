# --- switchyard ---
# Connection to the shared Postgres on construct_net.
# In production this is set by docker-compose; for local non-docker dev,
# set DATABASE_URL to a local Postgres or run a one-off compose with the postgres service.
DATABASE_URL=postgres://switchyard_user:change_me@localhost:5432/switchyard?sslmode=disable

# Port the server listens on (also serves the built Vue client at /).
PORT=4002

# Public base URL used in webhook payloads, attachment URLs, etc.
PUBLIC_URL=http://localhost:4002

# Where attachment files are written. In docker, this is /data/uploads (mounted volume).
UPLOAD_DIR=./uploads

# Bootstrap token printed to logs on first boot if no api_tokens exist.
# Use it to create the real per-user tokens, then revoke it.
# (Auto-generated if unset.)
BOOTSTRAP_TOKEN=
