{
  "name": "switchyard",
  "version": "0.0.0",
  "private": true,
  "workspaces": ["shared", "server", "client", "mcp"],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green 'bun run dev:server' 'bun run dev:client'",
    "dev:server": "cd server && bun run dev",
    "dev:client": "cd client && bun run dev",
    "dev:mcp": "cd mcp && bun run dev",
    "test:mcp": "cd mcp && bun run test",
    "test:server": "cd server && bun run test",
    "test:server:unit": "cd server && bun run test:unit",
    "test:server:integration": "cd server && bun run test:integration",
    "test:server:llm-obs": "cd server && bun test test/integration/llm-observations.test.ts",
    "test:client": "cd client && bun run test:e2e",
    "test": "bun run test:mcp && bun run test:server",
    "build": "(cd client && bun run build) && (cd server && bun run build)",
    "openapi:gen": "cd server && bun run openapi:gen",
    "api:gen": "(cd server && bun run openapi:gen) && (cd client && bun run api:gen) && (cd mcp && bun run api:gen)",
    "db:generate": "cd server && bun run db:generate",
    "db:migrate": "cd server && bun run db:migrate",
    "typecheck": "tsc -b shared server client mcp"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "bun@1.3.13"
}
