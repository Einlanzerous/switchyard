{
  "name": "@switchyard/client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "type-check": "vue-tsc -b --force",
    "build": "(cd ../shared && bun run build) && vue-tsc -b --force && vite build",
    "preview": "vite preview",
    "api:gen": "bunx openapi-typescript ../openapi.yaml -o ./src/lib/api.types.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:smoke": "playwright test --project=chromium e2e/smoke.spec.ts"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.8.1",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
    "@switchyard/shared": "workspace:*",
    "@tanstack/vue-query": "^5.62.0",
    "@tanstack/vue-virtual": "^3.10.9",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.3",
    "echarts": "^6.0.0",
    "lucide-vue-next": "^0.468.0",
    "markdown-it": "^14.1.0",
    "openapi-fetch": "^0.13.4",
    "pinia": "^2.3.0",
    "qrcode": "^1.5.4",
    "reka-ui": "^2.9.7",
    "tailwind-merge": "^2.5.5",
    "vue": "^3.5.13",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.5.0",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bun": "^1.1.14",
    "@types/dompurify": "^3.0.5",
    "@types/markdown-it": "^14.1.2",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "openapi-typescript": "^7.4.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.0",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
